generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RSVP {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  image         String?
  preferredName String?
  court         Int?
  createdAt     DateTime @default(now())
}

model Match {
  id        String   @id @default(cuid())
  court     Int
  round     Int
  team1p1   String
  team1p2   String
  team2p1   String
  team2p2   String
  createdAt DateTime @default(now())
}
