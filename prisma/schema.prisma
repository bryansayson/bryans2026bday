generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RSVP {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  image         String?
  preferredName String?
  court         Int?
  createdAt     DateTime @default(now())
}
