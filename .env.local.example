# Google OAuth — get these from https://console.cloud.google.com
# Create a project → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth secret — run: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# The secret that goes in your invite link: /?invite=THIS_VALUE
# Share the link: https://yoursite.com/?invite=YOUR_INVITE_SECRET
# Make it something hard to guess, e.g. a random word combo or UUID
INVITE_SECRET=your-invite-secret

# SQLite database file
DATABASE_URL="file:./dev.db"
